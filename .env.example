# Neo4j (new SearchPOC instance — separate from Elphie)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# OpenAI
OPENAI_API_KEY=sk-...

# AWS (uses ~/.aws/credentials by default — or set explicit keys here)
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# DynamoDB table names
PLATTERS_TABLE=craftmyplate-platters
VARIATIONS_TABLE=craftmyplate-variations

# CSV paths (relative to project root)
DYNAMODB_CSV=Search -POC data - Active DynamoDB Master Data.csv
SUPABASE_CSV=Search -POC data - Supabase Master Data.csv
